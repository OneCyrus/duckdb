# name: test/sql/json/issues/issue17252.test
# description: Case-insensitive field collisions create suffixed columns by default and can be merged with merge_duplicate_fields
# group: [issues]

statement ok
CREATE TABLE json_issue_17252(line VARCHAR);

statement ok
INSERT INTO json_issue_17252 VALUES
	('{"id":1,"obj":{"x":10}}'),
	('{"Id":2,"obj":{"X":20}}');

statement ok
COPY json_issue_17252 TO '__TEST_DIR__/issue17252.ndjson' (FORMAT csv, HEADER false, QUOTE '', ESCAPE '');

# Default behavior (merge_duplicate_fields=false): case-insensitive collisions are suffixed
query TT
SELECT column_name, column_type
FROM (DESCRIBE FROM read_ndjson_auto('__TEST_DIR__/issue17252.ndjson'))
ORDER BY column_name;
----
id	BIGINT
id_1	BIGINT
obj	STRUCT(x BIGINT, x_1 BIGINT)

query IIII
SELECT id, id_1, obj.x, obj.x_1
FROM read_ndjson_auto('__TEST_DIR__/issue17252.ndjson')
ORDER BY COALESCE(id, id_1);
----
1	NULL	10	NULL
NULL	2	NULL	20

# merge_duplicate_fields=true: root and nested case-collisions are merged into one name
query TT
SELECT column_name, column_type
FROM (DESCRIBE FROM read_ndjson_auto('__TEST_DIR__/issue17252.ndjson', merge_duplicate_fields = true))
ORDER BY column_name;
----
id	BIGINT
obj	STRUCT(x BIGINT)

query II
SELECT id, obj.x
FROM read_ndjson_auto('__TEST_DIR__/issue17252.ndjson', merge_duplicate_fields = true)
ORDER BY id;
----
1	10
2	20
